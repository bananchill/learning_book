    "@vue/test-utils": "^2.4.6",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.28.0",
    "eslint-plugin-vue": "^10.8.0",
    "jsdom": "^28.1.0",
    "postcss": "^8.5.4",
    "prettier": "^3.5.3",
    "tailwindcss": "^4.1.8",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^6.3.5",
    "vitest": "^3.2.1",
    "vue-eslint-parser": "^10.4.0"
